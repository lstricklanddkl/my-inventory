# ── Google Sheets (service account) ───────────────────────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value from the JSON key file WITHOUT the surrounding quotes.
# Keep the literal \n sequences — do not expand them into real line breaks.
# Should start with: -----BEGIN PRIVATE KEY-----\n
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n

# The spreadsheet ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here


# ── Google OAuth (for user login) ──────────────────────────────────────────────
# Create an OAuth 2.0 Client ID in Google Cloud Console:
#   APIs & Services → Credentials → Create Credentials → OAuth client ID
#   Application type: Web application
#   Authorised redirect URI: https://your-api.onrender.com/auth/callback
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Must exactly match the redirect URI set in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=https://your-api.onrender.com/auth/callback

# Where to send users after a successful login (your GitHub Pages URL)
APP_URL=https://yourusername.github.io/my-inventory

# Random secret used to sign JWTs — use any long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string


# ── Access control ─────────────────────────────────────────────────────────────
# At least one of these must be set — if both are empty, all logins are denied.

# Comma-separated list of specific email addresses to allow
ALLOWED_EMAILS=alice@gmail.com,bob@example.com

# Comma-separated list of domains — allows any Google account on that domain
ALLOWED_DOMAINS=yourcompany.com


# ── Optional ───────────────────────────────────────────────────────────────────
# Restrict CORS to your GitHub Pages origin in production
# ALLOWED_ORIGIN=https://yourusername.github.io

PORT=3000
